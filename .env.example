VITE_SUPABASE_URL=
VITE_SUPABASE_ANON_KEY=

# ImageKit is the primary asset store for content uploads.
# The browser only needs the URL endpoint; uploads are signed by the Supabase Edge Function.
VITE_IMAGEKIT_URL_ENDPOINT=

# Edge Function secrets, set with Supabase secrets rather than exposing in client code:
# IMAGEKIT_PUBLIC_KEY=
# IMAGEKIT_PRIVATE_KEY=

# Supabase fallback bucket used when ImageKit upload/signing is unavailable:
# content-assets

# Membership workflow uses Resend from Supabase Edge Functions.
# Set these with `npx supabase secrets set`, not as VITE_ client variables.
# RESEND_API_KEY=
# RESEND_FROM=DC-IAPM <onboarding@resend.dev>
# MEMBERSHIP_REPLY_TO=

# Private Supabase bucket used for membership photos, payment proofs, receipts and certificates:
# membership-assets

# Required only for seed scripts in CI environments.
# Never expose this in client code and never prefix it with VITE_.
SUPABASE_SERVICE_ROLE_KEY=
